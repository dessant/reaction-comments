{
  "name": "reaction-comments",
  "version": "5.0.1",
  "description": "A GitHub Action that deletes +1 comments and encourages the use of GitHub reactions.",
  "author": "Armin Sebastian",
  "license": "MIT",
  "homepage": "https://github.com/dessant/reaction-comments",
  "repository": {
    "url": "git+https://github.com/dessant/reaction-comments.git",
    "type": "git"
  },
  "bugs": {
    "url": "https://github.com/dessant/reaction-comments/issues"
  },
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "build": "ncc build src/index.js -o dist",
    "update": "ncu --dep prod,dev,peer --filterVersion '^*' --upgrade",
    "release": "commit-and-tag-version",
    "push": "git push --tags origin main"
  },
  "dependencies": {
    "@actions/artifact": "^6.2.1",
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/plugin-retry": "^8.1.0",
    "adm-zip": "^0.5.17",
    "dedent": "^1.7.2",
    "fs-extra": "^11.3.5",
    "joi": "^18.2.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.4",
    "commit-and-tag-version": "^12.7.3",
    "npm-check-updates": "^22.2.0",
    "prettier": "^3.8.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "github",
    "issues",
    "pull requests",
    "+1",
    "comments",
    "reactions",
    "github reactions",
    "automation",
    "github actions",
    "project management",
    "bot"
  ],
  "private": true
}
